# media-agent platform credentials
# Copy to .env and fill in your values. Never commit .env to git.

# === Image Generation (pick one) ===
# Supported: openrouter (recommended), openai, flux, ideogram
IMAGE_PROVIDER=openrouter

# OpenRouter (recommended) — one key for LLM + image generation
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# OpenAI (GPT Image) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Flux (via Replicate) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Ideogram — https://ideogram.ai/manage-api
IDEOGRAM_API_KEY=

# === Publishing Platforms (v1.0) ===

# Dev.to — https://dev.to/settings/extensions
DEVTO_API_KEY=

# Hashnode — https://hashnode.com/settings/developer
HASHNODE_API_KEY=
HASHNODE_PUBLICATION_ID=

# GitHub Pages — https://pages.github.com
# GITHUB_TOKEN is optional: only needed for GitHub API operations (e.g. creating repos)
# Publishing uses git push by default, which works with your existing SSH/HTTPS auth.
GITHUB_TOKEN=
GITHUB_PAGES_REPO_PATH=
GITHUB_PAGES_BRANCH=main
GITHUB_PAGES_SITE_URL=
GITHUB_PAGES_POSTS_DIR=_posts

# === Publishing Platforms (v1.1 — coming soon) ===

# Twitter/X — https://developer.x.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# WeChat Official Account — https://mp.weixin.qq.com
WECHAT_APP_ID=
WECHAT_APP_SECRET=
