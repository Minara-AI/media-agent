# media-agent platform credentials
# Copy to .env and fill in your values. Never commit .env to git.

# === Image Generation (pick one) ===
# Supported: openai, flux, ideogram
IMAGE_PROVIDER=openai

# OpenAI (GPT Image) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Flux (via Replicate) — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Ideogram — https://ideogram.ai/manage-api
IDEOGRAM_API_KEY=

# === Publishing Platforms (v1.0) ===

# Dev.to — https://dev.to/settings/extensions
DEVTO_API_KEY=

# Hashnode — https://hashnode.com/settings/developer
HASHNODE_API_KEY=
HASHNODE_PUBLICATION_ID=

# GitHub Pages — uses git push, no API key needed
# Configure repo path in content/config/platforms.yaml

# === Publishing Platforms (v1.1 — coming soon) ===

# Twitter/X — https://developer.x.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# WeChat Official Account — https://mp.weixin.qq.com
WECHAT_APP_ID=
WECHAT_APP_SECRET=
